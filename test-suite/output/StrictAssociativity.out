Entry custom:StrictAssociativity.expr is
[ "3" RIGHTA
  [ SELF; "op22"; NEXT
  | "atom3" ]
| "2" RIGHTA
  [ SELF; "post12"
  | SELF; "op12"; custom:StrictAssociativity.expr LEVEL "2"
  | "pre21"; NEXT
  | "pre22"; custom:StrictAssociativity.expr LEVEL "2"
  | "atom2" ]
| "1" LEFTA
  [ SELF; "post11"
  | SELF; "op10"; NEXT
  | "pre10"; NEXT
  | "pre11"; custom:StrictAssociativity.expr LEVEL "1"
  | "atom1" ]
| "0" RIGHTA
  [ IDENT "atom0" ] ]

