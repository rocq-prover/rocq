unblock_under_binders = __block Prop (forall x : bool, bool -> (__unblock (f x)) 0)
     : Blocked Prop
unblock_under_local_def = __block (nat -> nat) (fun x : nat => let y := S x in __unblock (g (S x)))
     : Blocked (nat -> nat)
repeated_unblocks = __block nat (__unblock stuck + __unblock stuck)
     : Blocked nat
nested_unblocks = __block nat (__unblock (__unblock nested))
     : Blocked nat
ordinary_identity_run = __block nat (__run nat nat stuck (fun x : nat => x))
     : Blocked nat
