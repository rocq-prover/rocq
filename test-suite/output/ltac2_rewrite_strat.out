k1 : unit -> unit
k1 :=
  fun _ =>
  rewrite_strat (seqs [subterms id; choice (subterm fail) fail; fail]) None
k2 : unit -> unit
k2 :=
  fun _ =>
  rewrite_strat
    (seq (seq (subterms (subterms fail)) (subterms (subterms fail)))
       (seq (subterms (try fail)) (subterms (repeat fail))))
    None
mytry : t -> unit
mytry := fun rewstrategy1 => rewrite_strat (choice rewstrategy1 id) None
myany : t -> unit
myany :=
  fun rewstrategy1 =>
  rewrite_strat (fix_ (fun fixident => try (seq rewstrategy1 fixident))) None
myrepeat : t -> unit
myrepeat :=
  fun rewstrategy1 =>
  rewrite_strat (seq rewstrategy1 (any rewstrategy1)) None
mybottomup : t -> unit
mybottomup :=
  fun rewstrategy1 =>
  rewrite_strat
    (fix_
       (fun fixident =>
        seq (choice (progress (subterms fixident)) rewstrategy1)
          (try fixident)))
    None
mytopdown : t -> unit
mytopdown :=
  fun rewstrategy1 =>
  rewrite_strat
    (fix_
       (fun fixident =>
        seq (choice rewstrategy1 (progress (subterms fixident)))
          (try fixident)))
    None
myinnermost : t -> unit
myinnermost :=
  fun rewstrategy1 =>
  rewrite_strat
    (fix_ (fun fixident => choice (subterm fixident) rewstrategy1)) 
    None
myoutermost : t -> unit
myoutermost :=
  fun rewstrategy1 =>
  rewrite_strat
    (fix_ (fun fixident => choice rewstrategy1 (subterm fixident))) 
    None
