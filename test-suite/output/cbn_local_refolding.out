     : string
     = fun x : nat => difference dnat x 1
     : nat -> nat
"def: let in dictionary body"
     : string
     = fun x : nat => difference dnat x 1
     : nat -> nat
"def: closed constructor control"
     : string
     = fun y : nat => y
     : nat -> nat
